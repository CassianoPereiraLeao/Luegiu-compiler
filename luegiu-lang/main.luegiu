int start_program(int argc, char argv) {
    for(int i = 0; i < 10; i++) {
        if(i == 5) {
            continue;
        } else if (i == 8) {
            break;
        } else {
            int x = i;
        }
    }

    int i = 0;
    i &= 0;
    int* ptr = &i;
    int x = 0;
    x |= 1;

    if(i& i || i == i && i == x || i << 3) {
        return;
    }
}